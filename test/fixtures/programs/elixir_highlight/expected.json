\"i\">puts</span><span class=\"p\">(</span><span class=\"i\">message</span><span class=\"p\">)</span>\n    <span class=\"p\">{</span><span class=\"a\">:ok</span><span class=\"p\">,</span> <span class=\"i\">message</span><span class=\"p\">}</span>\n  <span class=\"k\">end</span>\n\n  <span class=\"k\">defp</span> <span class=\"i\">format_name</span><span class=\"p\">(</span><span class=\"i\">name</span><span class=\"p\">)</span> <span class=\"k\">do</span>\n    <span class=\"i\">name</span>\n    <span class=\"o\">|&gt;</span> <span class=\"m\">String</span><span class=\"p\">.</span><span class=\"i\">trim</span><span class=\"p\">(</span><span class=\"p\">)</span>\n    <span class=\"o\">|&gt;</span> <span class=\"m\">String</span><span class=\"p\">.</span><span class=\"i\">capitalize</span><span class=\"p\">(</span><span class=\"p\">)</span>\n  <span class=\"k\">end</span>\n\n  <span class=\"k\">def</span> <span class=\"i\">run</span> <span class=\"k\">do</span>\n    <span class=\"sg\">~r/^[a-z]+$/i</span>\n    <span class=\"i\">nums</span> <span class=\"o\">=</span> <span class=\"k\">for</span> <span class=\"i\">x</span> <span class=\"o\">&lt;-</span> <span class=\"n\">1</span><span class=\"o\">..</span><span class=\"n\">10</span><span class=\"p\">,</span> <span class=\"i\">rem</span><span class=\"p\">(</span><span class=\"i\">x</span><span class=\"p\">,</span> <span class=\"n\">2</span><span class=\"p\">)</span> <span class=\"o\">==</span> <span class=\"n\">0</span><span class=\"p\">,</span> <span class=\"k\">do</span>: <span class=\"i\">x</span> <span class=\"o\">*</span> <span class=\"n\">0xFF</span>\n    <span class=\"i\">result</span> <span class=\"o\">=</span> <span class=\"m\">Enum</span><span class=\"p\">.</span><span class=\"i\">map</span><span class=\"p\">(</span><span class=\"i\">nums</span><span class=\"p\">,</span> <span class=\"k\">fn</span> <span class=\"i\">n</span> <span class=\"o\">-&gt;</span> <span class=\"i\">n</span> <span class=\"o\">+</span> <s